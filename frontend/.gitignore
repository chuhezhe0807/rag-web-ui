# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# 例外：US-014 把本地开发默认的 gateway 地址（NEXT_PUBLIC_API_URL=...）
# 放在 .env.development 里；里面没有密钥，需要进 git 让全队共享
!.env.development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
